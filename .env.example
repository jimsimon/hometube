# HomeTube environment variables.
#
# All values below are optional — HomeTube ships with sensible defaults
# and collects application credentials (Google OAuth, YouTube API key)
# through the in-app setup wizard. Use this file only if you need to
# override defaults for an advanced deployment.

# HTTP listener.
# HOST=0.0.0.0
# PORT=3000

# Persistent state lives under ./data/ split into three subdirectories
# so each can be mounted on different storage in production:
#   data/database/  — SQLite database (small, latency-sensitive)
#   data/tools/     — yt-dlp binary + cookies.txt
#   data/cache/     — on-disk DASH segment cache (large, regeneratable)

# SQLite database file (relative or absolute path).
# DATABASE_PATH=./data/database/app.db

# yt-dlp binary location. Default: resolved from PATH; the auto-updater
# falls back to ./data/tools/yt-dlp when the configured path is a bare
# command name.
# YTDLP_PATH=/usr/local/bin/yt-dlp

# yt-dlp Netscape cookie jar path.
# YTDLP_COOKIES_PATH=./data/tools/cookies.txt

# Segment cache root directory.
# CACHE_DIR=./data/cache

# Static asset directory (where Vite writes the built frontend bundles).
# Default in dev: ./frontend/dist
# Default in Docker: /app/static
# STATIC_DIR=./frontend/dist
